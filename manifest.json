{
  "manifest_version": 3,
  "name": "X Post Saver Local",
  "version": "0.1.0",
  "description": "閲覧中のXポストをローカルアプリへ保存",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://127.0.0.1:18765/*",
    "https://*.twimg.com/*",
    "https://video.twimg.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
